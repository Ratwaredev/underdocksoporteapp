{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UnderDock Command UI",
  "version": "0.1.13",
  "identifier": "dev.ratware.underdock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "UnderDock Command UI",
        "width": 1440,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico"
    ],
    "targets": [
      "nsis",
      "msi"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Ratwaredev/underdocksoporteapp/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFNDMzOTk0RkFBQjc0QkEKUldTNmRLdjZsRGxEam5BUmZtSTdMZ3RyeXFPRmcvSHUrWWpTZVNQY0c4NVBCK3o3eCt4MlBPVWEK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
